rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isHouseholdMember(hid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/households/$(hid)/members/$(request.auth.uid));
    }
    function householdRole(hid) {
      return get(/databases/$(database)/documents/households/$(hid)/members/$(request.auth.uid)).data.role;
    }
    function isHouseholdAdmin(hid) {
      return isHouseholdMember(hid) && householdRole(hid) == 'admin';
    }
    function hasHouseholdRole(hid, roles) {
      return isHouseholdMember(hid) && householdRole(hid) in roles;
    }
    function isHouseholdMutator(hid) {
      return hasHouseholdRole(hid, ['admin', 'cook', 'shopper']);
    }
    function isSoloHousehold(hid) {
      return isHouseholdMember(hid)
        && get(/databases/$(database)/documents/households/$(hid)).data.isJoint == false;
    }
    function hasFullPantryAccess(hid) {
      return isHouseholdAdmin(hid) || isSoloHousehold(hid);
    }
    function isConstrainedQuantityUpdate(hid) {
      return request.resource.data.householdId == hid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'quantity',
          'leftoverServings',
          'updatedAt',
        ])
        && request.resource.data.quantity is number
        && request.resource.data.quantity >= 0;
    }
    function isValidLeftoverCreate(hid) {
      return request.resource.data.householdId == hid
        && request.resource.data.section == 'leftover'
        && request.resource.data.relatedRecipeId is string
        && request.resource.data.relatedRecipeId.size() > 0
        && request.resource.data.leftoverServings is int
        && request.resource.data.leftoverServings > 0
        && request.resource.data.quantity is number
        && request.resource.data.quantity > 0
        && request.resource.data.unit is string
        && request.resource.data.unit.size() > 0
        && ingredientExistsForHousehold(hid, request.resource.data.ingredientId)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.expiryDate is timestamp
        && request.resource.data.expiryDate > request.resource.data.createdAt
        && request.resource.data.expiryDate <= request.resource.data.createdAt + duration.value(3, 'd');
    }
    function isValidLeftoverQuantityUpdate(hid) {
      return resource.data.section == 'leftover'
        && request.resource.data.section == 'leftover'
        && resource.data.relatedRecipeId is string
        && resource.data.relatedRecipeId.size() > 0
        && request.resource.data.relatedRecipeId == resource.data.relatedRecipeId
        && request.resource.data.expiryDate == resource.data.expiryDate
        && isConstrainedQuantityUpdate(hid)
        && request.resource.data.leftoverServings is int
        && request.resource.data.leftoverServings >= 0;
    }
    function hasHouseholdId(hid) {
      return request.resource.data.householdId == hid;
    }
    function inviteDoc(code) {
      return get(/databases/$(database)/documents/householdInvites/$(code));
    }
    function isDateKey(value) {
      return value is string
        && value.matches('^((\\d{4}-(01|03|05|07|08|10|12)-(0[1-9]|[12]\\d|3[01]))|(\\d{4}-(04|06|09|11)-(0[1-9]|[12]\\d|30))|(\\d{4}-02-(0[1-9]|1\\d|2[0-8]))|((\\d{2}(0[48]|[2468][048]|[13579][26])|([02468][048]00|[13579][26]00))-02-29))$');
    }
    function shoppingListRef(hid, listId) {
      return /databases/$(database)/documents/households/$(hid)/shoppingLists/$(listId);
    }
    function shoppingListExists(hid, listId) {
      return exists(shoppingListRef(hid, listId));
    }
    function globalIngredientRef(ingredientId) {
      return /databases/$(database)/documents/ingredients/$(ingredientId);
    }
    function customIngredientRef(hid, ingredientId) {
      return /databases/$(database)/documents/households/$(hid)/customIngredients/$(ingredientId);
    }
    function pantryItemRef(hid, pantryItemId) {
      return /databases/$(database)/documents/households/$(hid)/pantryItems/$(pantryItemId);
    }
    function ingredientExistsForHousehold(hid, ingredientId) {
      return ingredientId is string
        && ingredientId.size() > 0
        && (exists(globalIngredientRef(ingredientId)) || exists(customIngredientRef(hid, ingredientId)));
    }
    function isMassUnit(unit) {
      return unit in ['mg', 'g', 'kg', 'oz', 'lb'];
    }
    function isVolumeUnit(unit) {
      return unit in ['ml', 'l', 'fl-oz', 'pt', 'qt', 'gal', 'tsp', 'tbsp', 'cup'];
    }
    function unitsAllow(allowedUnits, unit) {
      return allowedUnits is list && (
        allowedUnits.hasAny([unit]) ||
        (isMassUnit(unit) && allowedUnits.hasAny(['mg', 'g', 'kg', 'oz', 'lb'])) ||
        (isVolumeUnit(unit) && allowedUnits.hasAny(['ml', 'l', 'fl-oz', 'pt', 'qt', 'gal', 'tsp', 'tbsp', 'cup']))
      );
    }
    function isValidIngredientReference(hid, ingredientId, unit) {
      return unit is string && (
        (exists(globalIngredientRef(ingredientId)) && unitsAllow(get(globalIngredientRef(ingredientId)).data.allowedUnits, unit)) ||
        (exists(customIngredientRef(hid, ingredientId)) && unitsAllow(get(customIngredientRef(hid, ingredientId)).data.allowedUnits, unit))
      );
    }
    function isValidLeftoverEventReference(hid) {
      return request.resource.data.pantryItemId is string
        && exists(pantryItemRef(hid, request.resource.data.pantryItemId))
        && get(pantryItemRef(hid, request.resource.data.pantryItemId)).data.section == 'leftover'
        && get(pantryItemRef(hid, request.resource.data.pantryItemId)).data.ingredientId == request.resource.data.ingredientId
        && get(pantryItemRef(hid, request.resource.data.pantryItemId)).data.unit == request.resource.data.unit
        && ingredientExistsForHousehold(hid, request.resource.data.ingredientId);
    }
    function isValidCustomIngredientData(hid) {
      return request.resource.data.scope == 'householdCustom'
        && request.resource.data.householdId == hid
        && request.resource.data.category is string
        && request.resource.data.defaultUnit is string
        && request.resource.data.allowedUnits is list
        && request.resource.data.allowedUnits.hasAny([request.resource.data.defaultUnit])
        && (request.resource.data.category != 'nonFood' || request.resource.data.isNonFood == true)
        && (request.resource.data.category != 'bulkStaple' || request.resource.data.isBulkCandidate == true)
        && (!('defaultPurchaseIntervalDays' in request.resource.data) || request.resource.data.defaultPurchaseIntervalDays == null || request.resource.data.defaultPurchaseIntervalDays > 0)
        && (!('pricePerUnitHint' in request.resource.data) || request.resource.data.pricePerUnitHint == null || request.resource.data.pricePerUnitHint >= 0);
    }
    function isValidCustomIngredient(hid, id) {
      return id.matches('^custom-.*') && isValidCustomIngredientData(hid);
    }
    function canManageWeeklyShoppingSchedule(hid) {
      return isHouseholdAdmin(hid) || (
        isHouseholdMember(hid) &&
        get(/databases/$(database)/documents/households/$(hid)).data.isJoint == false
      );
    }
    function isValidWeeklyShoppingSchedule(hid, scheduleId) {
      return scheduleId == 'weekly'
        && request.resource.data.keys().hasOnly([
          'householdId',
          'cadence',
          'isoWeekday',
          'effectiveFrom',
          'isActive',
          'createdAt',
          'updatedAt',
          'updatedByUserId',
        ])
        && request.resource.data.keys().size() == 8
        && request.resource.data.householdId == hid
        && request.resource.data.cadence == 'weekly'
        && request.resource.data.isoWeekday is int
        && request.resource.data.isoWeekday >= 1
        && request.resource.data.isoWeekday <= 7
        && isDateKey(request.resource.data.effectiveFrom)
        && request.resource.data.isActive is bool
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedByUserId is string
        && request.resource.data.updatedByUserId.size() > 0
        && request.resource.data.updatedByUserId == request.auth.uid;
    }

    match /shoppingCommandReceipts/{commandId} {
      allow read, write: if false;
    }

    match /users/{uid} {
      allow read, create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /ingredients/{ingredientId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /householdInvites/{code} {
      allow read: if isSignedIn() && resource.data.active == true;
      allow create, update: if isSignedIn()
        && request.resource.data.householdId is string
        && request.resource.data.active is bool
        && request.resource.data.role in ['member', 'shopper', 'cook']
        && (
          (
            request.resource.data.createdBy == request.auth.uid &&
            getAfter(/databases/$(database)/documents/households/$(request.resource.data.householdId)).data.creatorUserId == request.auth.uid
          ) ||
          isHouseholdAdmin(request.resource.data.householdId)
        );
      allow delete: if false;
    }

    match /households/{hid} {
      allow read: if isHouseholdMember(hid);
      allow create: if isSignedIn()
        && request.resource.data.creatorUserId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.isJoint is bool
        && request.resource.data.hasPremium is bool
        && request.resource.data.maxMembers in [1, 6];
      allow update, delete: if isHouseholdAdmin(hid);

      match /members/{uid} {
        allow read: if isHouseholdMember(hid);
        allow create: if isSignedIn()
          && (
            isHouseholdAdmin(hid) ||
            (
              request.auth.uid == uid &&
              getAfter(/databases/$(database)/documents/households/$(hid)).data.creatorUserId == request.auth.uid &&
              request.resource.data.role == 'admin'
            ) ||
            (
              request.auth.uid == uid &&
              request.resource.data.inviteCode is string &&
              inviteDoc(request.resource.data.inviteCode).data.active == true &&
              inviteDoc(request.resource.data.inviteCode).data.householdId == hid &&
              inviteDoc(request.resource.data.inviteCode).data.role == request.resource.data.role
            )
          );
        allow update, delete: if isHouseholdAdmin(hid);
      }
    }

    match /households/{hid}/shoppingSchedules/{scheduleId} {
      allow read: if isHouseholdMember(hid) && scheduleId == 'weekly';
      allow create: if canManageWeeklyShoppingSchedule(hid)
        && isValidWeeklyShoppingSchedule(hid, scheduleId);
      allow update: if canManageWeeklyShoppingSchedule(hid)
        && isValidWeeklyShoppingSchedule(hid, scheduleId)
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if canManageWeeklyShoppingSchedule(hid)
        && scheduleId == 'weekly';
    }

    match /recipes/{recipeId} {
      allow read: if isSignedIn() && (
        resource.data.visibility == 'public' || isHouseholdMember(resource.data.householdId)
      );
      allow create, update: if isSignedIn()
        && hasHouseholdRole(request.resource.data.householdId, ['admin', 'cook']);
      allow delete: if isSignedIn()
        && hasHouseholdRole(resource.data.householdId, ['admin', 'cook']);

      match /ingredients/{ingredientLineId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/recipes/$(recipeId)).data.visibility == 'public' ||
          isHouseholdMember(get(/databases/$(database)/documents/recipes/$(recipeId)).data.householdId)
        );
        allow create, update: if isSignedIn()
          && hasHouseholdRole(getAfter(/databases/$(database)/documents/recipes/$(recipeId)).data.householdId, ['admin', 'cook'])
          && request.resource.data.recipeId == recipeId
          && isValidIngredientReference(
            getAfter(/databases/$(database)/documents/recipes/$(recipeId)).data.householdId,
            request.resource.data.ingredientId,
            request.resource.data.unit
          );
        allow delete: if isSignedIn()
          && hasHouseholdRole(get(/databases/$(database)/documents/recipes/$(recipeId)).data.householdId, ['admin', 'cook']);
      }
    }

    match /households/{hid}/customIngredients/{id} {
      allow read: if isHouseholdMember(hid);
      allow create: if isHouseholdMutator(hid) && isValidCustomIngredient(hid, id);
      allow update: if isHouseholdMutator(hid)
        && isValidCustomIngredientData(hid);
      allow delete: if isHouseholdAdmin(hid);
    }

    match /households/{hid}/purchases/{id} {
      allow read: if isHouseholdMember(hid);
      allow create: if isHouseholdMutator(hid)
        && request.resource.data.householdId == hid
        && isValidIngredientReference(hid, request.resource.data.ingredientId, request.resource.data.unit);
      allow update, delete: if false;
    }

    match /households/{hid}/shoppingLists/{listId} {
      allow read: if isHouseholdMember(hid);
      allow write: if false;

      match /items/{itemId} {
        allow read: if isHouseholdMember(hid)
          && shoppingListExists(hid, listId);
        allow write: if false;
      }
    }

    // Planner drafts are server-owned command inputs and must never be exposed
    // to Firebase clients. Admin SDK and Cloud Functions bypass Rules.
    match /households/{hid}/shoppingAllocationDrafts/{draftId} {
      allow read, write: if false;
    }

    match /households/{hid}/daySettings/{id} {
      allow read: if isHouseholdMember(hid);
      allow create, update: if isHouseholdAdmin(hid)
        && hasHouseholdId(hid);
      allow delete: if isHouseholdAdmin(hid);
    }

    match /households/{hid}/pantryItems/{id} {
      allow read: if isHouseholdMember(hid);
      allow create: if (
        request.resource.data.section == 'leftover'
          ? (hasFullPantryAccess(hid) || hasHouseholdRole(hid, ['cook']))
            && isValidLeftoverCreate(hid)
          : hasFullPantryAccess(hid)
            && request.resource.data.householdId == hid
            && isValidIngredientReference(hid, request.resource.data.ingredientId, request.resource.data.unit)
      );
      allow update: if resource.data.section == 'leftover'
        ? (hasFullPantryAccess(hid) || hasHouseholdRole(hid, ['cook']))
          && isValidLeftoverQuantityUpdate(hid)
        : request.resource.data.section != 'leftover'
          && (
            hasFullPantryAccess(hid) ||
            (hasHouseholdRole(hid, ['cook', 'shopper']) && isConstrainedQuantityUpdate(hid))
          );
      allow delete: if hasFullPantryAccess(hid);
    }

    match /households/{hid}/wasteEvents/{id} {
      allow read: if isHouseholdMember(hid);
      allow create: if (hasFullPantryAccess(hid) || hasHouseholdRole(hid, ['cook']))
        && request.resource.data.householdId == hid
        && (
          isValidLeftoverEventReference(hid) ||
          isValidIngredientReference(hid, request.resource.data.ingredientId, request.resource.data.unit)
        );
      allow update, delete: if false;
    }

    match /households/{hid}/consumptionEvents/{id} {
      allow read: if isHouseholdMember(hid);
      allow create: if (hasFullPantryAccess(hid) || hasHouseholdRole(hid, ['cook']))
        && request.resource.data.householdId == hid
        && (
          request.resource.data.source == 'leftover'
            ? isValidLeftoverEventReference(hid)
            : isValidIngredientReference(hid, request.resource.data.ingredientId, request.resource.data.unit)
        );
      allow update, delete: if false;
    }

    match /households/{hid}/inventoryAdjustmentEvents/{id} {
      allow read: if isHouseholdMember(hid);
      allow create: if (hasFullPantryAccess(hid) || hasHouseholdRole(hid, ['shopper']))
        && request.resource.data.householdId == hid
        && request.resource.data.reason in ['manualCorrection', 'manualRestock']
        && request.resource.data.quantityDelta is number
        && request.resource.data.quantityDelta != 0
        && request.resource.data.previousQuantity is number
        && request.resource.data.previousQuantity >= 0
        && request.resource.data.newQuantity is number
        && request.resource.data.newQuantity >= 0
        && isValidIngredientReference(hid, request.resource.data.ingredientId, request.resource.data.unit);
      allow update, delete: if false;
    }

    match /households/{hid}/{collection}/{document=**} {
      allow read: if isHouseholdMember(hid)
        && collection != 'shoppingSchedules'
        && collection != 'shoppingLists'
        && collection != 'shoppingAllocationDrafts'
        && collection != 'members'
        && collection != 'daySettings'
        && collection != 'pantryItems'
        && collection != 'wasteEvents'
        && collection != 'consumptionEvents'
        && collection != 'inventoryAdjustmentEvents'
        && collection != 'customIngredients'
        && collection != 'purchases';
      allow write: if isHouseholdMutator(hid)
        && collection != 'shoppingSchedules'
        && collection != 'shoppingLists'
        && collection != 'shoppingAllocationDrafts'
        && collection != 'members'
        && collection != 'daySettings'
        && collection != 'pantryItems'
        && collection != 'wasteEvents'
        && collection != 'consumptionEvents'
        && collection != 'inventoryAdjustmentEvents'
        && collection != 'customIngredients'
        && collection != 'purchases';
    }

    match /{rootCollection}/{document=**} {
      allow read, write: if false;
    }
  }
}
