<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only: permit cleartext HTTP to the Firebase Local Emulator Suite.
  The Android emulator reaches the host via 10.0.2.2; loopback hosts are
  included for completeness. This file lives under src/debug so release
  builds keep Android's default no-cleartext policy.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
