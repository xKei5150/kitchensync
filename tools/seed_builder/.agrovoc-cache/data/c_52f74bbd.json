fao.org/aos/agrovoc/xl_en_75742dd4"}]},{"uri":"http://aims.fao.org/aos/agrovoc/c_7249","type":"skos:Concept","http://aims.fao.org/aos/agrontology#isSourceOf":{"uri":"http://aims.fao.org/aos/agrovoc/c_52f74bbd"},"prefLabel":[{"lang":"pt","value":"grão de sorgo"},{"lang":"be","value":"сорга (зерне)"},{"lang":"pt-BR","value":"sorgo"},{"lang":"hi","value":"ज्वार दाना"},{"lang":"ru","value":"зерно сорго"},{"lang":"ar","value":"حبوب الذرة الرفيعة"},{"lang":"es","value":"Sorgo en grano"},{"lang":"fr","value":"sorgho en grain"},{"lang":"sw","value":"matama"},{"lang":"de","value":"Sorghumhirse (Getreide)"},{"lang":"en","value":"sorghum grain"},{"lang":"fa","value":"دانه ذرت خوشه‌ای"},{"lang":"hu","value":"cirokmag"},{"lang":"it","value":"Grano di sorgo"},{"lang":"ja","value":"ソルガム穀粒"},{"lang":"lo","value":"ເມັດເຂົ້າຝ້າງ"},{"lang":"pl","value":"Sorgo (ziarno)"},{"lang":"zh","value":"高粱"},{"lang":"id","value":"Bijirin sorghum"},{"lang":"ms","value":"Bijirin sorghum"},{"lang":"tr","value":"tane sorgum"},{"lang":"th","value":"ข้าวฟ่างเมล็ด"},{"lang":"ka","value":"სორგო (მარცვალი)"}]},{"uri":"http://aims.fao.org/aos/agrovoc/skosCollection_c346d422","type":"skos:Collection","skos:member":{"uri":"http://aims.fao.org/aos/agrovoc/c_52f74bbd"},"prefLabel":[{"lang":"th","value":"กลุ่มข้าวฟ่างและธัญพืชเมล็ดเล็ก"},{"lang":"ar","value":"مجموعة الدخن والذرة الرفيعة"},{"lang":"zh","value":"小米和高粱组"},{"lang":"ru","value":"Просо и сорго (список терминов)"},{"lang":"es","value":"Grupo sobre Mijos y Sorgo"},{"lang":"fr","value":"Groupe sur Millets et Sorgho"},{"lang":"en","value":"Millets and Sorghum Group"}]},{"uri":"http://aims.fao.org/aos/agrovoc/xDef_53b133de","http://art.uniroma2.it/ontologies/vocbench#hasSource":"FAO et OMS. 2019. Norme pour la farine de sorgho. Norme Codex, No. CXS 173-1989. Rome. https://www.fao.org/fao-who-codexalimentarius","dct:created":{"type":"http://www.w3.org/2001/XMLSchema#dateTime","value":"2024-04-12T14:34:13"},"http://www.w3.org/1999/02/22-rdf-syntax-ns#value":{"lang":"fr","value":"La farine de sorgho est le produit obtenu à partir des grains de Sorghum bicolor (L.) Moench par procédé de mouture industrielle au cours duquel le tégument est éliminé, une grande partie du germe est retirée et l’endosperme est broyé en poudre suffisamment fine."}},{"uri":"http://aims.fao.org/aos/agrovoc/xDef_69103c41","http://art.uniroma2.it/ontologies/vocbench#hasSource":"FAO y OMS. 2019. Norma para la harina de sorgo. Norma Codex, No. CXS 173-1989. Roma. https://www.fao.org/fao-who-codexalimentarius","dct:created":{"type":"http://www.w3.org/2001/XMLSchema#dateTime","value":"2024-04-12T14:36:50"},"http://www.w3.org/1999/02/22-rdf-syntax-ns#value":{"lang":"es","value":"La harina de sorgo es el producto que se obtiene de granos de Sorghum bicolor (L.) Moench mediante un proceso de molienda industrial en el curso del cual se elimina el tegumento y gran parte del germen y se tritura el endosperma hasta alcanzar un grado de finura apropiado."}},{"uri":"http://aims.fao.org/aos/agrovoc/xDef_fab1c701","http://art.uniroma2.it/ontologies/vocbench#hasSource":"FAO & WHO. 2019. Standard for Sorghum Flour. Codex Standard, No. CXS 173-1989. Rome. https://www.fao.org/fao-who-codexalimentarius","dct:created":{"type":"http://www.w3.org/2001/XMLSchema#dateTime","value":"2024-04-12T14:31:07"},"http://www.w3.org/1999/02/22-rdf-syntax-ns#value":{"lang":"en","value":"Sorghum flour is the product obtained from grains of Sorghum bicolor (L.) Moench through a process of industrial milling during which the seed coat is removed and the germ is removed to a large extent and the endosperm is comminuted to a suitable degree of fineness."}},{"uri":"http://aims.fao.org/aos/agrovoc/xl_ar_7bda344d","type":"http://www.w3.org/2008/05/skos-xl#Label","dct:created":{"type":"http://www.w3.org/2001/XMLSchema#dateTime","value":"2024-04-12T14:46:25"},"http://rdfs.org/ns/void#inDataset":{"uri":"http://aims.fao.org/aos/agrovoc/void.ttl#Agrovoc"},"skos:notation":{"type":"http://aims.fao