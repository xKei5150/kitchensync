voc/xDef_0580f388"},{"uri":"http://aims.fao.org/aos/agrovoc/xDef_80ef36d8"},{"uri":"http://aims.fao.org/aos/agrovoc/xDef_0925d598"}],"exactMatch":{"uri":"https://lod.nal.usda.gov/nalt/24522"},"inScheme":{"uri":"http://aims.fao.org/aos/agrovoc"},"narrower":{"uri":"http://aims.fao.org/aos/agrovoc/c_8b5af9e9"},"prefLabel":[{"lang":"pt","value":"cottage"},{"lang":"be","value":"зярнёны тварог"},{"lang":"sw","value":"jibini la jumba"},{"lang":"en","value":"cottage cheese"},{"lang":"es","value":"Queso cottage"},{"lang":"ru","value":"сыр домашнего изготовления"},{"lang":"sv","value":"grynost"},{"lang":"fi","value":"raejuusto"},{"lang":"fr","value":"cottage cheese"},{"lang":"cs","value":"tvarohy"},{"lang":"de","value":"Hüttenkäse"},{"lang":"it","value":"Fiocchi di latte"},{"lang":"tr","value":"cottage peyniri"},{"lang":"zh","value":"农家干酪"},{"lang":"ka","value":"მარცვლოვანი ხაჭო"},{"lang":"ar","value":"جبن القريش"}],"related":{"uri":"http://aims.fao.org/aos/agrovoc/c_10209"},"http://www.w3.org/2008/05/skos-xl#altLabel":{"uri":"http://aims.fao.org/aos/agrovoc/xl_zh_7532ded4"},"http://www.w3.org/2008/05/skos-xl#prefLabel":[{"uri":"http://aims.fao.org/aos/agrovoc/xl_pt_f1076181"},{"uri":"http://aims.fao.org/aos/agrovoc/xl_be_2089a44c"},{"uri":"http://aims.fao.org/aos/agrovoc/xl_sw_c856fb80"},{"uri":"http://aims.fao.org/aos/agrovoc/xl_ar_617609e2"},{"uri":"http://aims.fao.org/aos/agrovoc/xl_ka_5284d34e"},{"uri":"http://aims.fao.org/aos/agrovoc/xl_zh_55008fbe"},{"uri":"http://aims.fao.org/aos/agrovoc/xl_tr_fe47f2ee"},{"uri":"http://aims.fao.org/aos/agrovoc/xl_it_ea559b76"},{"uri":"http://aims.fao.org/aos/agrovoc/xl_de_a8b6a779"},{"uri":"http://aims.fao.org/aos/agrovoc/xl_cs_1a6c07db"},{"uri":"http://aims.fao.org/aos/agrovoc/xl_fr_840c2293"},{"uri":"http://aims.fao.org/aos/agrovoc/xl_fi_c6618715"},{"uri":"http://aims.fao.org/aos/agrovoc/xl_sv_0b721705"},{"uri":"http://aims.fao.org/aos/agrovoc/xl_ru_6b15618e"},{"uri":"http://aims.fao.org/aos/agrovoc/xl_es_f3b47b0c"},{"uri":"http://aims.fao.org/aos/agrovoc/xl_en_8d035423"}]},{"uri":"http://aims.fao.org/aos/agrovoc/xDef_0580f388","http://art.uniroma2.it/ontologies/vocbench#hasSource":"FAO y OMS. 2022. Norma para el queso cottage. Norma Codex, No. CXS 273-1969. Roma. https://www.fao.org/fao-who-codexalimentarius","dct:created":{"type":"http://www.w3.org/2001/XMLSchema#dateTime","value":"2024-04-11T16:58:34"},"http://www.w3.org/1999/02/22-rdf-syntax-ns#value":{"lang":"es","value":"El queso cottage es un queso blando no madurado y sin corteza de conformidad con la Norma general para el queso (CXS 283-1978) y la Norma colectiva para el queso no madurado incluido el queso fresco (CXS 221-2001). El cuerpo tiene un color casi blanco y una textura granular que consiste en gránulos discretos y blandos de cuajada de tamaño relativamente uniforme, de aproximadamente 3 mm–12 mm según se desee un tipo de cuajada más pequeña o más grande, y posiblemente esté cubierto por una mezcla cremosa."}},{"uri":"http://aims.fao.org/aos/agrovoc/xDef_0925d598","http://art.uniroma2.it/ontologies/vocbench#hasSource":"FAO & WHO. 2022. Standard for Cottage Cheese. Codex Standard, No. CXS  273-1968. Rome. https://www.fao.org/fao-who-codexalimentarius","dct:created":{"type":"http://www.w3.org/2001/XMLSchema#dateTime","value":"2018-06-28T11:48:35Z"},"dct:modified":{"type":"http://www.w3.org/2001/XMLSchema#dateTime","value":"2024-04-11T16:55:48"},"http://www.w3.org/1999/02/22-rdf-syntax-ns#value":{"lang":"en","value":"Cottage Cheese is a soft, rindless, unripened cheese in conformity with the General Standard for Cheese (CXS 283-1978) and the Group Standard for Unripened Cheese Including Fresh Cheese (CXS 221-2001). The body has a near white colour and a granular texture consisting of discrete individual soft curd granules of relatively uniform size, from approximately 3–12 mm depending on whether small or large type of curd is desired, and possibly covered with a creamy mixture. "}},{"uri":"http://aims.fao.org/aos/agrovoc/xDef_80ef36d8","http://art.uniroma2.it/ontologies/vocbench#hasSource":"FAO et OMS. 2023. Norme pour le cottage cheese. Norme Codex, No. CXS 273-1968. Rome. https://www.fao.org/fao-who-codexalimentarius","dct:created":{"type":"http://www.w3.org/2001/XMLSchema#dateTime","value":"2024-04-11T16:57:09"},"dct:modified":{"type":"http://www.w3.org/2001/XMLSchema#dateTime","value":"2025-02-25T10:49:35"},"http://www.w3.org/1999/02/22-rdf-syntax-ns#value":{"lang":"fr","value":"Le Cottage Cheese est un fromage non affiné à pâte molle sans croûte, conformément à la Norme générale pour le fromage (CXS 283-1978) et à la Norme pour les fromages non affinés, y compris le fromage frais (CXS 221-2001). La pâte a une couleur blanc cassé et une texture granulaire consistant en grains de caillé mou individuels discrets d’une taille relativement uniforme, soit d’environ 3 à 12 mm, en fonction du type de grains (petits ou gros) désiré, et éventuellement recouvert d’un mélange crémeux."}},{"uri":"http://aims.fao.org/aos/agrovoc/xl_ar_617609e2","type":"http://www.w3.org/2008/05/skos-xl#Label","dct:created":{"type":"http://www.w3.org/2001/XMLSchema#dateTime","value":"2023-09-19T10:23:42Z"},"http://rdfs.org/ns/void#inDataset":{"uri":"http://aims.fao.org/aos/agrovoc/void.ttl#Agrovoc"},"skos:notation":{"type":"http://aims.fao.org/aos/agrovoc/AgrovocCode","value":"c95dc3fd"},"http://www.w3.org/2008/05/skos-xl#literalForm":{"lang":"ar","value":"جبن القريش"}},{"uri":"http://aims.fao.org/aos/agrovoc/xl_be_2089a44c","type":"http://www.w3.org/2008/05/skos-xl#Label","dct:created":{"type":"http://www.w3.org/2001/XMLSchema#dateTime","value":"2025-09-30T06:35:13"},"http://rdfs.org/ns/void#inDataset":{"uri":"http://aims.fao.org/aos/agrovoc/void.ttl#Agrovoc"},"skos:notation":{"type":"http://aims.fao.org/aos/agrovoc/AgrovocCode","value":"c95dc3fd"},"http://www.w3.org/2008/05/skos-xl#literalForm":{"lang":"be","value":"зярнёны тварог"}},{"uri":"http://aims.fao.org/aos/agrovoc/xl_cs_1a6c07db","type":"http://www.w3.or