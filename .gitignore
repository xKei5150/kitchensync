# KitchenSync
# Firebase configs (per-env, contain sensitive identifiers)
lib/firebase_options.dart
lib/firebase_options_dev.dart
lib/firebase_options_prod.dart
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
ios/Runner/GoogleService-Info-dev.plist
ios/Runner/GoogleService-Info-prod.plist

# Service account credentials (NEVER commit)
tools/seed_uploader/service-account*.json
!tools/seed_uploader/service-account.example.json

# Coverage
coverage/

# Generated code
**/*.freezed.dart
**/*.g.dart

# Seed builder: transient USDA dataset (downloaded, not committed)
tools/seed_builder/food.csv

# Node tooling dependencies (installed, not committed)
/node_modules/
tools/seed_uploader/node_modules/

# Local agent / session tooling state (not project source)
.entire/
.omo/
.superpowers/
package.json
bun.lock

# Nested Flutter build output (service package)
services/shopping_allocation_planner/build/

# Local visual-verification screenshots (flutter drive gallery)
screenshots/
